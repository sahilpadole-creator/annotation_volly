# Frontend origins allowed to call backend (comma-separated). Use * only for testing.
CORS_ORIGINS=https://sahilpadole-creator.github.io,http://localhost:5173

# ---- Touch model ----
TOUCH_PYTHON=/opt/models/touch/.venv/bin/python
TOUCH_SCRIPT=/opt/models/touch/evaluate_video.py
TOUCH_CHECKPOINT=/opt/models/touch/checkpoints/best-epoch=09-val_touch_f1=0.827.ckpt
TOUCH_DEVICE=cpu
TOUCH_STRIDE=8
TOUCH_BATCH_SIZE=8

# ---- 5-class skill model ----
SKILL_PYTHON=/opt/models/skill/.venv/bin/python
SKILL_SCRIPT=/opt/models/skill/infer_skill_on_peaks.py
SKILL_CONFIG=/opt/models/skill/config/slowfast_skill_sahil_5class_16f.py
SKILL_CHECKPOINT=/opt/models/skill/work_dirs/slowfast_skill_sahil_5class/best_acc_top1_epoch_28.pth

# Optional GT XML used by your rulebase post-processing
# SKILL_GT_XML=/opt/models/data/Women/annotations_224002.xml
